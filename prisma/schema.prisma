datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                String   @id @default(cuid())
  googleId          String   @unique
  email             String   @unique
  minecraftUsername String?
  minecraftUuid     String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
